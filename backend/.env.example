# ============================================================================
# Backend .env.example — copy to .env and fill in real values
# NEVER commit the real .env file
# ============================================================================

# --- DhanHQ Broker Credentials --------------------------------------------
# Get these from https://dhanhq.co/docs/v1/overview/#getting-started-with-dhanapis
DHAN_CLIENT_ID=your_dhan_client_id
DHAN_ACCESS_TOKEN=your_dhan_access_token

# --- Database --------------------------------------------------------------
# PostgreSQL connection string
# Example: postgresql+psycopg2://trader:traderpass@localhost:5432/trading_db
DB_URL=postgresql+psycopg2://trader:traderpass@localhost:5432/trading_db

# --- Redis (Celery broker + result backend) --------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- JWT Auth --------------------------------------------------------------
JWT_SECRET=change_me_to_a_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- App -------------------------------------------------------------------
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# --- Trading defaults ------------------------------------------------------
DEFAULT_CAPITAL=1000000        # ₹10,00,000 default starting capital
RISK_PER_TRADE_PCT=1.0         # 1% fixed-risk per trade (Fitschen Ch 11)
LIVE_LOOP_INTERVAL_SEC=30      # live loop ticks every 30s
MARKET_OPEN_IST=09:15
MARKET_CLOSE_IST=15:30

# --- LIVE TRADING SAFETY RAILS ---------------------------------------------
# ⚠️  MASTER KILL SWITCH. Must be True for ANY real order to reach DhanHQ.
# If False, the system forces paper_mode regardless of what the API request says.
# Set to True ONLY after thorough paper testing.
LIVE_TRADING_ENABLED=false

# DhanHQ product types per segment
# NSE_EQ:  CNC (delivery) or INTRADAY (MIS)
# NSE_FNO: INTRADAY (MIS) for options/futures
# MCX:     INTRADAY (MIS) for commodities
ORDER_PRODUCT_TYPE_EQ=CNC
ORDER_PRODUCT_TYPE_FNO=INTRADAY
ORDER_PRODUCT_TYPE_MCX=INTRADAY

# Order type for entries: MARKET (immediate fill) or LIMIT (price-controlled)
ORDER_TYPE_DEFAULT=MARKET

# Circuit breaker: stop the live loop if daily realized loss exceeds this ₹ amount
MAX_DAILY_LOSS_INR=50000

# Retry config for transient broker failures
ORDER_RETRY_ATTEMPTS=3
ORDER_RETRY_DELAY_SEC=2.0
